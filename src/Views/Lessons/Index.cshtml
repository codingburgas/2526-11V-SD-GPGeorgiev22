@model IReadOnlyList<WarehouseManagementSchool.ViewModels.LessonListItemViewModel>
@{
    ViewData["Title"] = "Lessons";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="mb-1">Learning Lessons</h2>
        <p class="text-secondary mb-0">Explore the core topics required for warehouse management software design.</p>
    </div>
</div>

<div class="row g-3">
    @foreach (var lesson in Model)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm lesson-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-2">
                        <span class="badge text-bg-secondary">@lesson.CategoryName</span>
                    </div>
                    <h5 class="card-title">@lesson.Title</h5>
                    <p class="card-text text-secondary flex-grow-1">@lesson.Summary</p>
                    <a asp-controller="Lessons" asp-action="Details" asp-route-id="@lesson.Id" class="btn btn-outline-primary btn-sm align-self-start">Read More</a>
                </div>
            </div>
        </div>
    }
</div>
