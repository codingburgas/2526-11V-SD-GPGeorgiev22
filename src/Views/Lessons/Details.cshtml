@model WarehouseManagementSchool.ViewModels.LessonDetailsViewModel
@{
    ViewData["Title"] = "Lesson Details";
}

<article class="lesson-details">
    <h2>@Model.Title</h2>
    <p><span class="badge bg-secondary">@Model.CategoryName</span></p>
    <div class="card shadow-sm">
        <div class="card-body">
            <p class="card-text">@Model.Content</p>
        </div>
    </div>
    <a asp-controller="Lessons" asp-action="Index" class="btn btn-link mt-3">Back to Lessons</a>
</article>
