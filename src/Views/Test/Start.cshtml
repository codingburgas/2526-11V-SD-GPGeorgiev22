@model WarehouseManagementSchool.ViewModels.TestStartViewModel
@{
    ViewData["Title"] = "Start Test";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="mb-1">Knowledge Test</h2>
        <p class="text-muted mb-0">Answer all questions and submit for immediate grading.</p>
    </div>
    @if (Model.Questions.Count > 0)
    {
        <span class="badge text-bg-primary fs-6">Total points: @Model.TotalPoints</span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">
        @Model.ErrorMessage
    </div>
}

@if (Model.Questions.Count == 0)
{
    <div class="alert alert-info" role="alert">
        No test can be generated right now.
    </div>
}
else
{
    <form asp-action="Submit" method="post">
        @Html.AntiForgeryToken()

        @for (var i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions[i];
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <input type="hidden" name="questionIds" value="@question.Id" />

                    <h5 class="card-title">Question @(i + 1)</h5>
                    <p class="card-text mb-2">@question.Text</p>
                    <p class="text-muted small mb-3">
                        Category: @question.CategoryName | Difficulty: @question.Difficulty | Points: @question.Points
                    </p>

                    @for (var j = 0; j < question.Answers.Count; j++)
                    {
                        var answer = question.Answers[j];
                        var inputId = $"q{question.Id}_a{answer.Id}";
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" id="@inputId" name="answers[@question.Id]" value="@answer.Id" required />
                            <label class="form-check-label" for="@inputId">@answer.Text</label>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Submit Test</button>
            <a asp-action="Start" class="btn btn-outline-secondary">Generate New Test</a>
        </div>
    </form>
}
