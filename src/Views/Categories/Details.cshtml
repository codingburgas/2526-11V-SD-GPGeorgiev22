@model IReadOnlyList<WarehouseManagementSchool.Models.Lesson>
@{
    ViewData["Title"] = "Category Details";
}

<h2>@ViewData["CategoryName"]</h2>
<p class="text-secondary">Lessons in this category.</p>

@if (Model.Count == 0)
{
    <p>No lessons are currently assigned to this category.</p>
}
else
{
    <div class="list-group">
        @foreach (var lesson in Model)
        {
            <a asp-controller="Lessons" asp-action="Details" asp-route-id="@lesson.Id" class="list-group-item list-group-item-action">
                @lesson.Title
            </a>
        }
    </div>
}

<a asp-controller="Categories" asp-action="Index" class="btn btn-link mt-3">Back to Categories</a>
